LLM_BASE_URL=https://api.openai.com/v1
LLM_API_KEY=
LLM_MODEL=gpt-4.1-mini
# Leave these empty to reuse the LLM provider above. Any OpenAI-compatible
# endpoint (including OpenRouter or a self-hosted model) can be used instead.
TRANSLATION_ENABLED=true
TRANSLATION_PROVIDER_NAME=OpenAI
TRANSLATION_BASE_URL=
TRANSLATION_API_KEY=
TRANSLATION_MODEL=
TRANSLATION_TIMEOUT_SECONDS=20
ENVIRONMENT=PRODUCTION
LLM_DEBUG_LOGGING=false
EMBEDDING_BASE_URL=https://api.openai.com/v1
EMBEDDING_API_KEY=
EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_DIMENSIONS=1536
EXTERNAL_SEARCH_ENABLED=false
EXTERNAL_SEARCH_TIMEOUT_SECONDS=10
EXTERNAL_SEARCH_RESULT_LIMIT=5
EXTERNAL_SEARCH_ALLOWED_DOMAINS=
# Docker Compose: postgresql+asyncpg://<POSTGRES_USER>:<POSTGRES_PASSWORD>@postgres:5432/<POSTGRES_DB>
DATABASE_URL=
KNOWLEDGE_DATA_DIR=/app/data
RETRIEVAL_LIMIT=6
REDIS_URL=redis://redis:6379/0
SESSION_TTL_SECONDS=1800
MAX_MESSAGE_LENGTH=2000
CORS_ORIGIN=http://localhost:8080
SESSION_COOKIE_NAME=icivi_session
SESSION_COOKIE_SECURE=false
